# Copy to .env (or just export these) and adjust to your MySQL setup.
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=trading_crm

# Or set the full URL directly (overrides the DB_* parts above):
# DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/trading_crm

# MT5 mode: "mock" (default, no credentials) or "real" (Windows + MetaTrader5)
MT5_MODE=mock

# Commission engine: $ per lot traded
COMMISSION_PER_LOT=5

# Worker interval (seconds) and market feed interval (seconds)
SYNC_INTERVAL_SECONDS=60
MARKET_FEED_INTERVAL_SECONDS=1
